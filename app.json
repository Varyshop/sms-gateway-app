{
  "expo": {
    "name": "Varyshop SMS",
    "slug": "sms-gateway-app",
    "version": "1.5.0",
    "scheme": "smsgateway",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111827"
    },
    "android": {
      "package": "com.varyshop.smsgatewayapp",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111827"
      },
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.SEND_SMS",
        "android.permission.RECEIVE_SMS",
        "android.permission.READ_SMS",
        "android.permission.READ_PHONE_STATE",
        "android.permission.READ_PHONE_NUMBERS",
        "android.permission.WRITE_SECURE_SETTINGS",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.varyshop.smsgatewayapp"
    },
    "plugins": [
      "expo-router",
      "./modules/gateway-service/app.plugin.js",
      "./modules/apk-installer/app.plugin.js"
    ],
    "extra": {
      "eas": {
        "projectId": "7f25e2eb-8419-4b90-868a-c14fb7172494"
      }
    }
  }
}