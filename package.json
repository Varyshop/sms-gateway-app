{
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/native": "^7.1.8",
    "expo": "^54.0.0",
    "expo-camera": "^17.0.10",
    "expo-constants": "~18.0.9",
    "expo-dev-client": "~6.0.18",
    "expo-font": "~14.0.9",
    "expo-linking": "~8.0.8",
    "expo-router": "~6.0.12",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-system-ui": "~6.0.8",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "5.6.0",
    "react-native-screens": "~4.16.0",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.1.10",
    "typescript": "5.9.2"
  },
  "main": "index.ts",
  "name": "sms-gateway-app",
  "private": true,
  "scripts": {
    "android": "expo run:android --port 8085",
    "build-apk": "cd android && ./gradlew assembleRelease 2>&1",
    "copy-apk": "cp android/app/build/outputs/apk/release/app-release.apk ./app-release.apk",
    "install-apk": "adb install ./android/app/build/outputs/apk/release/app-release.apk",
    "build:android": "EAS_NO_VCS=1 eas build --platform android",
    "dev": "expo start --port 8085 -c",
    "eas:build:apk": "EAS_NO_VCS=1 eas build --platform android --profile production-apk",
    "eas:build:app-bundle": "EAS_NO_VCS=1 eas build --platform android --profile production",
    "ios": "expo run:ios",
    "grant-permission": "adb shell pm grant com.varyshop.smsgatewayapp android.permission.WRITE_SECURE_SETTINGS",
    "prebuild": "expo prebuild --platform android"
  },
  "version": "1.7.1"
}